# NICEPAY_SECRET_KEY=
# NEXT_PUBLIC_NICEPAY_CLIENT_KEY=  # 결제창(JS SDK)용 – 동일 키 또는 테스트 키
# NICEPAY_API_BASE_URL=            # 선택. 미설정 시 개발=sandbox, 프로덕션=live
